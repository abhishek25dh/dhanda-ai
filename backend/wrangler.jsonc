{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dhanda-ai-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-21",
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "vars": {
    "OPENROUTER_MODEL": "openai/gpt-oss-120b:free",
    "APP_VERSION_CODE": "5",
    "APP_VERSION_NAME": "0.1.4",
    "APP_RELEASE_NOTES": "Small release APK, instant cached cards, graceful refresh, download progress, and install-ready updates.",
    "APP_APK_KEY": "app/dhanda-ai.apk",
    "APP_APK_URL": "https://github.com/abhishek25dh/dhanda-ai/releases/download/v0.1.4/app-arm64-v8a-release.apk"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dhanda-ai",
      "database_id": "ce329529-46a1-4cf3-8a38-b37d9f5adceb"
    }
  ],
  "r2_buckets": [
    {
      "binding": "AUDIO_BUCKET",
      "bucket_name": "dhanda-ai-audio"
    }
  ],
  "observability": {
    "enabled": true
  }
}
